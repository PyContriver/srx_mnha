# ─── Juniper SRX MNHA Configuration ─────────────────────────────────────────
# Fill in your values and run:
#   python3 srx_mnha_setup.py
#
# Priority: CLI args > this file > built-in defaults
# ─────────────────────────────────────────────────────────────────────────────

# ── Node 1 (primary) ─────────────────────────────────────────────────────────
# Management IP used to SSH into node 1
N1_HOST=10.0.0.1
N1_USER=admin
# ICL point-to-point link IP (/30)
N1_ICL_IP=10.255.255.1/30
# LAN-facing IP
N1_LAN_IP=10.10.10.1/24
N1_ICL_IFACE=ge-0/0/0
N1_LAN_IFACE=ge-0/0/2

# ── Node 2 (secondary) ───────────────────────────────────────────────────────
# Management IP used to SSH into node 2
N2_HOST=10.0.0.2
N2_USER=admin
# ICL point-to-point link IP — peer of node 1
N2_ICL_IP=10.255.255.2/30
# LAN-facing IP
N2_LAN_IP=10.10.10.2/24
N2_ICL_IFACE=ge-0/0/0
N2_LAN_IFACE=ge-0/0/2

# ── SSH ───────────────────────────────────────────────────────────────────────
SSH_PORT=22
# Uncomment SSH_PASSWORD only if you accept the risk of storing it in a file.
# Leave commented to be prompted securely at runtime.
# SSH_PASSWORD=Admin@123

# ── WAN Interfaces ────────────────────────────────────────────────────────────
N1_WAN_IFACE=ge-0/0/1
N2_WAN_IFACE=ge-0/0/1
# WAN IPs — 10.20.20.x/24 (distinct from mgmt/ICL/LAN ranges)
N1_WAN_IP=10.20.20.1/24
N2_WAN_IP=10.20.20.2/24
# Default gateway — upstream router on the same WAN subnet
WAN_GATEWAY=10.20.20.254

# ── MNHA Timers (optional — Junos defaults are fine for most deployments) ─────
# Uncomment only if you need to tune failover timing
# HB_INTERVAL=1000
# HB_THRESHOLD=3
