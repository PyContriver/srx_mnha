# ─── Juniper SRX MNHA Configuration ─────────────────────────────────────────
# Fill in your values and run:
#   python3 srx_full_setup.py
#
# Priority: CLI args > this file > built-in defaults
# ─────────────────────────────────────────────────────────────────────────────

# ── Management / SSH ──────────────────────────────────────────────────────────
N1_HOST=10.0.0.1
N2_HOST=10.0.0.2
N1_USER=admin
N2_USER=admin
SSH_PORT=22
# SSH_PASSWORD=Admin@123    ← uncomment only if you accept the security risk

# ── ICL (Inter-Chassis Link) ──────────────────────────────────────────────────
N1_ICL_IFACE=ge-0/0/0
N2_ICL_IFACE=ge-0/0/0
N1_ICL_IP=10.255.255.1/30
N2_ICL_IP=10.255.255.2/30

# ── LAN Interfaces (comma-separated, same order for ifaces and IPs) ───────────
# Interface names are the same on both nodes (physical ports)
LAN_IFACES=ge-0/0/2,ge-0/0/3,ge-0/0/4,ge-0/0/5,ge-0/0/6

# Each node gets its own IP — same subnet, different host address
N1_LAN_IPS=10.30.30.1/24,10.31.31.1/24,10.32.32.1/24,10.33.33.1/24,10.34.34.1/24
N2_LAN_IPS=10.30.30.2/24,10.31.31.2/24,10.32.32.2/24,10.33.33.2/24,10.34.34.2/24

# ── WAN Interfaces (comma-separated) ─────────────────────────────────────────
WAN_IFACES=ge-0/0/7,ge-0/0/8,ge-0/0/9,ge-0/0/10,ge-0/0/11

N1_WAN_IPS=10.20.20.1/24,10.21.21.1/24,10.22.22.1/24,10.23.23.1/24,10.24.24.1/24
N2_WAN_IPS=10.20.20.2/24,10.21.21.2/24,10.22.22.2/24,10.23.23.2/24,10.24.24.2/24

# Gateway per WAN (comma-separated, same order as WAN_IFACES)
WAN_GATEWAYS=10.20.20.254,10.21.21.254,10.22.22.254,10.23.23.254,10.24.24.254

# ── MNHA Timers (optional — Junos defaults used if not set) ───────────────────
# HB_INTERVAL=1000
# HB_THRESHOLD=3
