# ─── Juniper SRX MNHA Configuration ─────────────────────────────────────────
# Fill in your values and run:
#   python3 srx_full_setup.py
#
# Priority: CLI args > this file > built-in defaults
# ─────────────────────────────────────────────────────────────────────────────

# ── Management / SSH ──────────────────────────────────────────────────────────
N1_HOST=10.0.0.1
N2_HOST=10.0.0.2
N1_USER=admin
N2_USER=admin
SSH_PORT=22
# SSH_PASSWORD=Admin@123    ← uncomment only if you accept the security risk

# ── ICL (Inter-Chassis Link) ──────────────────────────────────────────────────
N1_ICL_IFACE=ge-0/0/0
N2_ICL_IFACE=ge-0/0/0
N1_ICL_IP=10.255.255.1/30
N2_ICL_IP=10.255.255.2/30

# ── LAN Interfaces ────────────────────────────────────────────────────────────
LAN_IFACES=ge-0/0/2
N1_LAN_IPS=10.30.30.1/24
N2_LAN_IPS=10.30.30.2/24

# ── WAN Interfaces ────────────────────────────────────────────────────────────
# ge-0/0/5 and ge-0/0/6 added as additional WANs
# Script will remove any existing LAN (trust zone) config on these before applying
WAN_IFACES=ge-0/0/1,ge-0/0/5,ge-0/0/6
N1_WAN_IPS=10.20.20.1/24,10.21.21.1/24,10.22.22.1/24
N2_WAN_IPS=10.20.20.2/24,10.21.21.2/24,10.22.22.2/24
WAN_GATEWAYS=10.20.20.254,10.21.21.254,10.22.22.254

# ── MNHA Timers (optional — Junos defaults used if not set) ───────────────────
# HB_INTERVAL=1000
# HB_THRESHOLD=3
